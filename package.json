{
  "name": "icefall",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b --noEmit",
    "gen-floor": "vite-node tools/gen-floor.ts",
    "gen-fixtures": "vite-node tools/gen-fixtures.ts"
  },
  "dependencies": {
    "@noble/hashes": "1.6.1"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/eslint": "9.6.1",
    "@types/node": "20.17.10",
    "@typescript-eslint/parser": "8.18.2",
    "@typescript-eslint/utils": "8.18.2",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.17.0",
    "fflate": "0.8.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.2",
    "vite": "6.0.3",
    "vitest": "2.1.8"
  }
}
